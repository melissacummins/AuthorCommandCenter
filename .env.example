# Supabase Configuration
# Get these from your Supabase project: Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Planner — Google Calendar (optional)
# Enables the Planner's Calendar view: see your Google Calendar events and turn
# to-dos into time blocks (with reminders). Browser-only OAuth — no backend, no
# client secret. Create a free OAuth 2.0 *Web application* client ID in Google
# Cloud Console (APIs & Services > Credentials), add your app's URL to the
# Authorized JavaScript origins, and paste the client ID here. Leave unset to
# hide/disable the calendar connection.
# VITE_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# Link Shortener
# Public base URL the UI shows when copying short URLs.
# Set this to your custom subdomain so copied URLs don't include /l/ —
# host-based routing in vercel.json handles the bare-path slug form.
# VITE_SHORT_LINK_BASE_URL=https://read.yourdomain.com

# Server-side env vars (set these on Vercel — NOT prefixed with VITE_):
#   SUPABASE_URL              = same as VITE_SUPABASE_URL
#   SUPABASE_SERVICE_ROLE_KEY = Supabase service role key (Settings > API)
#   IP_HASH_SALT              = any random string; rotates IP hashes if changed

# Planner AI assistant (bring-your-own-key)
# Customers paste their OWN Anthropic key in Settings → AI assistant; it's
# stored encrypted with this secret. This is NOT an Anthropic key — it's a
# random value you invent (like the other *_ENCRYPTION_SECRET vars).
#   ANTHROPIC_KEY_ENCRYPTION_SECRET = random string, 32+ chars

# Link-in-bio page (shown at the bare short-link domain, e.g. read.yourdomain.com)
# These are now the LEGACY single-tenant fallback. With custom domains enabled,
# the bio/redirect handlers resolve the user from the request's domain via the
# custom_domains table, and per-user bio title/subtitle live in bio_settings.
# Keep these set for the owner so existing links keep working:
#   BIO_USER_ID  = your auth.users.id (find in Supabase: Authentication > Users)
#   BIO_TITLE    = page heading, e.g. "Melissa Cummins" (default "Links")
#   BIO_SUBTITLE = optional tagline below the heading

# Host routing (multi-tenant link shortener)
# Comma-separated hostnames that should ALWAYS serve the app (the SPA) rather
# than be treated as a member's link/bio domain. *.vercel.app and localhost are
# always treated as app hosts automatically — only set this if you attach a
# CUSTOM domain to the app itself (e.g. app.melissacummins.com).
#   APP_HOSTS=app.melissacummins.com
